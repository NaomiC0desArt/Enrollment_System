{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dev-log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Email": {
    "Host": "localhost",
    "Port": 1025
  },
  "ApiSettings": {
    "BaseUrl": "https://localhost:7035"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "UniversitySystem": "Debug"
    }
  }
}
